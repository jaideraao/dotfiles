# Include *.conf

Host *
    AddKeysToAgent yes
    Compression yes
    # HashKnownHosts yes
    UseKeychain yes
    VerifyHostKeyDNS yes
    VisualHostKey yes

Host github.com
    HostName github.com
    IdentityFile ~/.ssh/id_github
    RequestTTY no
    User git

Host fgt-aws
    HostName ec2-54-237-109-153.compute-1.amazonaws.com
    IdentityFile ~/.ssh/aws
    User admin
