set height unlimited
set history save
set mem inaccessible-by-default off
set mi-async
set pagination off
set print array off
set print array-indexes on
set print pretty on
set python print-stack full
set tui compact-source on
set tui tab-width 4
# set verbose on

# tui reg all
# tui focus cmd
# tui enable

# file ./bin/app.elf

# target extended-remote /dev/cu.usbmodem7BAE9BAB1
# monitor swd_scan
# attach 1

# load
# compare-sections
# start
