set auto-load safe-path ~/Workspace
set height unlimited
set history save
set mem inaccessible-by-default off
set mi-async
set pagination off
set print array off
set print array-indexes on
set print pretty on
set python print-stack full
set tui compact-source on
set tui tab-width 4
# set verbose on

# tui reg all
tui focus cmd
tui enable
